# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# For all files
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# For cpp files
[*.{c++,cc,cpp,cxx,h,h++,hh,hpp,hxx,inl,ipp,tlh,tli,tpp,t++,txx}]
cpp_indent_case_contents_when_block = true
cpp_indent_access_specifiers = unset
cpp_new_line_before_open_brace_namespace = same_line
cpp_space_before_function_open_parenthesis = remove
cpp_new_line_close_brace_same_line_empty_function = true
cpp_space_before_block_open_brace = true  # opening brace of blocks
cpp_space_before_comma = false
cpp_space_after_comma = true
cpp_new_line_before_else = false
indent_style = space
indent_size = 4
spaces_around_operators = true

# For Makefile
[Makefile]
indent_style = tab
indent_size = 4
